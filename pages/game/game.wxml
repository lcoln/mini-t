<view class="game-container" catchtouchmove="onGlobalTouchMove" catchtouchend="onGlobalTouchEnd">
  <!-- 顶部状态栏 -->
  <view class="status-bar">
    <view class="status-item wave">
      <text class="status-icon">🏰</text>
      <text class="status-value">{{level}}-{{waveInLevel}}</text>
      <text class="status-label">关</text>
    </view>
    <view class="status-item gold">
      <text class="status-icon">💰</text>
      <text class="status-value gold-value">{{gold}}</text>
    </view>
    <view class="status-item lives">
      <text class="status-icon">❤️</text>
      <text class="status-value lives-value">{{lives}}</text>
    </view>
    <view class="status-item score">
      <text class="status-icon">⭐</text>
      <text class="status-value">{{score}}</text>
    </view>
    <view class="pause-btn" bindtap="togglePause">
      <text>⏸</text>
    </view>
  </view>

  <view class="battle-banner" wx:if="{{gameState !== 'prep'}}">
    <view class="banner-chip {{selectedBlessingKey ? 'active' : ''}}">
      <text>{{selectedBlessingIcon}} {{selectedBlessingName}}</text>
    </view>
    <view class="banner-chip banner-chip-subtle">
      <text>强化 {{runBuffSummary}}</text>
    </view>
    <text class="banner-tip">拖动同塔合成升级 · 第{{nextSupplyWave}}波补给</text>
  </view>

  <!-- 战前准备条 -->
  <view class="prep-hud" wx:if="{{gameState === 'prep'}}">
    <view class="prep-hud-top">
      <view class="prep-copy">
        <text class="prep-hud-eyebrow">开波准备</text>
        <text class="prep-hud-title">{{selectedBlessingKey ? '继续放 1 座塔，然后开第一波' : '先选 1 个战术祝福'}}</text>
      </view>
      <view class="prep-progress {{fieldTowerCount > 0 ? 'ready' : ''}}">
        <text>{{fieldTowerCount > 0 ? '已布阵 1/1' : '待布阵 0/1'}}</text>
      </view>
    </view>

    <view class="prep-step-line">
      <text class="prep-step {{selectedBlessingKey ? 'done' : 'active'}}">1 选祝福</text>
      <text class="prep-step {{selectedBlessingKey && fieldTowerCount === 0 ? 'active' : (fieldTowerCount > 0 ? 'done' : '')}}">2 放塔</text>
      <text class="prep-step {{canStartBattle ? 'active ready' : ''}}">3 开波</text>
    </view>

    <view class="blessing-quick-list {{selectedBlessingKey ? 'compact' : ''}}">
      <view
        class="blessing-quick-card {{selectedBlessingKey === item.key ? 'selected' : ''}}"
        wx:for="{{blessingOptions}}"
        wx:key="key"
        data-key="{{item.key}}"
        bindtap="selectBlessing"
      >
        <text class="blessing-quick-icon">{{item.icon}}</text>
        <text class="blessing-quick-name">{{item.name}}</text>
        <text class="blessing-quick-subtitle" wx:if="{{!selectedBlessingKey}}">{{item.subtitle}}</text>
      </view>
    </view>

    <view class="prep-footer compact">
      <text class="prep-footnote {{canStartBattle ? 'ready' : ''}}">{{canStartBattle ? '已准备好，直接开第一波' : prepActionHint}}</text>
      <button class="btn primary prep-start-btn {{canStartBattle ? '' : 'disabled'}}" bindtap="startBattle" disabled="{{!canStartBattle}}">开始第一波</button>
    </view>
  </view>

  <!-- 游戏Canvas -->
  <view class="battlefield-wrap {{gameState === 'prep' ? 'prep-mode' : ''}}">
    <canvas 
      type="2d" 
      id="gameCanvas" 
      class="game-canvas {{gameState === 'prep' ? 'prep-canvas' : ''}}"
      bindtouchstart="onCanvasTouchStart"
    ></canvas>
    <view class="prep-slot-layer" wx:if="{{gameState === 'prep'}}">
      <view
        class="prep-slot {{item.occupied ? 'occupied' : ''}} {{selectedInventoryIndex !== -1 && !item.occupied ? 'selectable' : ''}}"
        wx:for="{{prepTowerSlots}}"
        wx:key="key"
        data-row="{{item.row}}"
        data-col="{{item.col}}"
        bindtap="handlePrepSlotTap"
        style="left: {{item.left}}px; top: {{item.top}}px;"
      ></view>
    </view>
  </view>

  <!-- 合成提示 -->
  <view class="merge-hint" wx:if="{{showMergeHint}}">
    <text class="merge-text">✨ 松开合成升级 ✨</text>
  </view>

  <!-- 底部仓库区域 -->
  <view class="inventory-area">
    <view class="inventory-header">
      <text class="inventory-title">🏰 防御塔仓库</text>
      <view class="summon-btn {{gold < summonCost || inventoryFull ? 'disabled' : ''}}" catchtap="summonTower">
        <text class="summon-icon">✨</text>
        <text class="summon-text">召唤</text>
        <text class="summon-cost">💰{{summonCost}}</text>
      </view>
    </view>
    
    <view class="inventory-hint">
      <text>点选或拖拽放置，相同塔可合成</text>
    </view>
    
    <view class="inventory-grid">
      <view 
        class="inventory-slot {{item ? 'has-tower tower-' + item.type : 'empty'}} {{draggingSlotIndex === index ? 'dragging' : ''}} {{mergeTargetSlotIndex === index ? 'merge-target' : ''}} {{selectedInventoryIndex === index ? 'selected' : ''}}"
        wx:for="{{inventorySlots}}"
        wx:key="index"
        data-index="{{index}}"
        catchtouchstart="onInventoryTouchStart"
        bindtap="handleInventorySlotTap"
      >
        <block wx:if="{{item}}">
          <view class="slot-tower slot-tower-{{item.type}}">
            <view wx:if="{{item.type === 'fire'}}" class="tower-shape fire-shape">
              <view class="fire-body"></view>
              <view class="fire-flame"></view>
            </view>
            <view wx:elif="{{item.type === 'ice'}}" class="tower-shape ice-shape">
              <view class="ice-crystal"></view>
              <view class="ice-shine"></view>
            </view>
            <view wx:elif="{{item.type === 'nature'}}" class="tower-shape nature-shape">
              <view class="nature-trunk"></view>
              <view class="nature-canopy"></view>
            </view>
            <view wx:elif="{{item.type === 'arcane'}}" class="tower-shape arcane-shape">
              <view class="arcane-base"></view>
              <view class="arcane-gem"></view>
            </view>
            <view wx:elif="{{item.type === 'lightning'}}" class="tower-shape lightning-shape">
              <view class="lightning-coil"></view>
              <view class="lightning-orb"></view>
            </view>
          </view>
          <view class="tower-level-badge">
            <text class="tower-level">Lv.{{item.level}}</text>
          </view>
          <view class="tower-name">
            <text>{{item.name}}</text>
          </view>
        </block>
        <block wx:else>
          <text class="empty-slot">+</text>
        </block>
      </view>
    </view>
  </view>

  <!-- 拖动浮层 -->
  <view 
    class="drag-floating-tower" 
    wx:if="{{dragFloating}}"
    style="left:{{dragFloatingX}}px; top:{{dragFloatingY}}px; border-color:{{dragFloatingColor}};"
  >
    <view class="drag-float-body slot-tower-{{dragFloatingType}}" style="background: radial-gradient(circle at 30% 30%, #fff, {{dragFloatingColor}}); box-shadow: 0 0 15px {{dragFloatingColor}}, inset 0 -3px 8px rgba(0,0,0,0.3);">
      <text class="drag-float-emoji">{{dragFloatingEmoji}}</text>
    </view>
    <view class="drag-float-level">
      <text>Lv.{{dragFloatingLevel}}</text>
    </view>
  </view>

  <view class="overlay" wx:if="{{showWaveChoice}}">
    <view class="panel supply-panel">
      <text class="panel-title">战术补给</text>
      <text class="supply-subtitle">{{waveChoiceTitle}}</text>
      <view class="supply-list">
        <view
          class="supply-card"
          wx:for="{{waveChoiceOptions}}"
          wx:key="key"
          data-key="{{item.key}}"
          bindtap="applyWaveChoice"
        >
          <text class="supply-icon">{{item.icon}}</text>
          <text class="supply-name">{{item.title}}</text>
          <text class="supply-desc">{{item.description}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 暂停面板 -->
  <view class="overlay" wx:if="{{gameState === 'paused'}}">
    <view class="panel">
      <text class="panel-title">游戏暂停</text>
      <view class="panel-stats">
        <view class="panel-stat">
          <text class="panel-stat-label">当前关卡</text>
          <text class="panel-stat-value">第{{level}}关 第{{waveInLevel}}/{{totalWavesInLevel}}波</text>
        </view>
        <view class="panel-stat">
          <text class="panel-stat-label">当前金币</text>
          <text class="panel-stat-value gold-text">💰 {{gold}}</text>
        </view>
      </view>
      <button class="btn primary" bindtap="resumeGame">继续游戏</button>
      <button class="btn secondary" bindtap="restartGame">重新开始</button>
      <button class="btn secondary" bindtap="backToMenu">返回菜单</button>
    </view>
  </view>

  <!-- 游戏结束面板 -->
  <view class="overlay" wx:if="{{gameState === 'gameover'}}">
    <view class="panel gameover-panel">
      <text class="panel-title gameover">💀 防守失败!</text>
      <view class="panel-stats">
        <view class="panel-stat">
          <text class="panel-stat-label">最终分数</text>
          <text class="panel-stat-value big">{{score}}</text>
        </view>
        <view class="panel-stat">
          <text class="panel-stat-label">坚持波数</text>
          <text class="panel-stat-value">{{wave}}</text>
        </view>
        <view class="record" wx:if="{{isNewRecord}}">
          <text>🏆 新纪录!</text>
        </view>
      </view>
      <button class="btn primary" bindtap="restartGame">再来一局</button>
      <button class="btn secondary" bindtap="backToMenu">返回菜单</button>
    </view>
  </view>
</view>
