.game-container {
  position: relative;
  width: 100vw;
  height: 100vh;
  background: linear-gradient(180deg, #0a1a0a 0%, #152515 50%, #0a1a0a 100%);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* 顶部状态栏 */
.status-bar {
  display: flex;
  align-items: center;
  padding: 15rpx 20rpx;
  background: linear-gradient(180deg, rgba(30, 60, 30, 0.95) 0%, rgba(15, 30, 15, 0.9) 100%);
  border-bottom: 3rpx solid rgba(80, 255, 80, 0.4);
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.5);
}

.battle-banner {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 10rpx 18rpx 14rpx;
  background: linear-gradient(180deg, rgba(10, 22, 10, 0.92) 0%, rgba(6, 14, 6, 0.85) 100%);
  border-bottom: 2rpx solid rgba(80, 255, 80, 0.16);
}

.banner-chip {
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.12);
  background: rgba(255, 255, 255, 0.05);
}

.banner-chip.active {
  border-color: rgba(255, 215, 120, 0.55);
  box-shadow: 0 0 18rpx rgba(255, 215, 120, 0.2);
}

.banner-chip-subtle {
  border-color: rgba(120, 255, 120, 0.16);
  background: rgba(120, 255, 120, 0.05);
}

.banner-chip text {
  font-size: 20rpx;
  color: #f7f5d0;
  font-weight: 600;
}

.banner-chip-subtle text {
  color: rgba(205, 255, 205, 0.78);
}

.banner-tip {
  flex: 1;
  font-size: 20rpx;
  line-height: 1.45;
  color: rgba(220, 255, 220, 0.75);
}

.status-item {
  display: flex;
  align-items: center;
  margin-right: 20rpx;
  background: linear-gradient(135deg, rgba(0, 0, 0, 0.4) 0%, rgba(0, 0, 0, 0.2) 100%);
  padding: 10rpx 18rpx;
  border-radius: 25rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  box-shadow: inset 0 2rpx 5rpx rgba(255, 255, 255, 0.05);
}

.status-icon {
  font-size: 26rpx;
  margin-right: 8rpx;
}

.status-value {
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.5);
}

.status-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-left: 4rpx;
}

.gold-value {
  color: #ffd700;
  text-shadow: 0 0 15rpx rgba(255, 215, 0, 0.6), 0 2rpx 4rpx rgba(0, 0, 0, 0.5);
  min-width: 70rpx;
  font-size: 32rpx;
}

.lives-value {
  color: #ff6666;
  text-shadow: 0 0 15rpx rgba(255, 102, 102, 0.6), 0 2rpx 4rpx rgba(0, 0, 0, 0.5);
}

.pause-btn {
  margin-left: auto;
  width: 65rpx;
  height: 65rpx;
  background: linear-gradient(135deg, rgba(80, 255, 80, 0.2) 0%, rgba(40, 120, 40, 0.3) 100%);
  border: 2rpx solid rgba(80, 255, 80, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  box-shadow: 0 0 15rpx rgba(80, 255, 80, 0.3);
}

.pause-btn:active {
  transform: scale(0.95);
  background: rgba(80, 255, 80, 0.3);
}

/* 游戏Canvas */
.battlefield-wrap {
  position: relative;
  width: 100%;
  height: 320px;
  flex-shrink: 0;
  overflow: hidden;
}

.battlefield-wrap.prep-mode {
  height: 320px;
}

.game-canvas {
  display: block;
  width: 100%;
  height: 100%;
  min-height: 0;
  background: linear-gradient(180deg, #0f1f0f 0%, #1a2a1a 50%, #0f1f0f 100%);
}

.game-canvas.prep-canvas {
  min-height: 0;
}

.prep-slot-layer {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.prep-slot {
  position: absolute;
  width: 54rpx;
  height: 54rpx;
  margin-left: -27rpx;
  margin-top: -27rpx;
  border-radius: 50%;
  border: 2rpx dashed rgba(220, 255, 220, 0.42);
  background: rgba(255, 255, 255, 0.05);
  box-shadow: 0 0 0 8rpx rgba(120, 255, 120, 0.06);
  pointer-events: auto;
}

.prep-slot.selectable {
  border-color: rgba(255, 215, 120, 0.8);
  background: rgba(255, 215, 120, 0.12);
  box-shadow: 0 0 18rpx rgba(255, 215, 120, 0.34);
}

.prep-slot.occupied {
  opacity: 0;
  pointer-events: none;
}

/* 合成提示 */
.merge-hint {
  position: absolute;
  top: 35%;
  left: 50%;
  transform: translate(-50%, -50%);
  padding: 30rpx 60rpx;
  background: linear-gradient(135deg, rgba(255, 215, 0, 0.95) 0%, rgba(255, 170, 0, 0.95) 100%);
  border-radius: 30rpx;
  box-shadow: 0 0 50rpx rgba(255, 215, 0, 0.8), inset 0 2rpx 10rpx rgba(255, 255, 255, 0.3);
  animation: mergeHintPulse 0.5s ease-in-out infinite;
  z-index: 50;
}

.merge-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #1a1a00;
  text-shadow: 0 2rpx 4rpx rgba(255, 255, 255, 0.3);
}

@keyframes mergeHintPulse {
  0%, 100% { transform: translate(-50%, -50%) scale(1); box-shadow: 0 0 50rpx rgba(255, 215, 0, 0.8); }
  50% { transform: translate(-50%, -50%) scale(1.08); box-shadow: 0 0 70rpx rgba(255, 215, 0, 1); }
}

/* 底部仓库区域 */
.inventory-area {
  background: linear-gradient(0deg, rgba(5, 15, 5, 0.98) 0%, rgba(20, 40, 20, 0.95) 100%);
  border-top: 3rpx solid rgba(80, 255, 80, 0.5);
  padding: 8rpx 10rpx 15rpx;
  box-shadow: 0 -8rpx 25rpx rgba(0, 0, 0, 0.5);
  display: flex;
  flex-direction: column;
}

.inventory-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 4rpx;
  padding: 0 10rpx;
}

.inventory-title {
  font-size: 24rpx;
  color: #50ff50;
  font-weight: bold;
  text-shadow: 0 0 15rpx rgba(80, 255, 80, 0.5);
}

.summon-btn {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #ffd700 0%, #ff9500 100%);
  padding: 10rpx 18rpx;
  border-radius: 25rpx;
  box-shadow: 0 0 20rpx rgba(255, 215, 0, 0.5), inset 0 2rpx 8rpx rgba(255, 255, 255, 0.3);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.summon-btn:active {
  transform: scale(0.96);
  box-shadow: 0 0 30rpx rgba(255, 215, 0, 0.8);
}

.summon-btn.disabled {
  background: linear-gradient(135deg, #555 0%, #333 100%);
  box-shadow: none;
  opacity: 0.5;
  border-color: rgba(255, 255, 255, 0.1);
}

.summon-icon {
  font-size: 22rpx;
  margin-right: 6rpx;
}

.summon-text {
  font-size: 22rpx;
  font-weight: bold;
  color: #1a1a00;
  margin-right: 8rpx;
}

.summon-cost {
  font-size: 20rpx;
  color: #1a1a00;
  font-weight: bold;
}

.inventory-hint {
  text-align: center;
  margin-bottom: 4rpx;
}

.inventory-hint text {
  font-size: 18rpx;
  color: rgba(150, 200, 150, 0.7);
}

.inventory-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 6rpx;
}

.inventory-slot {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, rgba(20, 40, 20, 0.8) 0%, rgba(10, 25, 10, 0.9) 100%);
  border: 2rpx solid rgba(80, 255, 80, 0.25);
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  box-shadow: inset 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.inventory-slot.has-tower {
  border-color: rgba(80, 255, 80, 0.5);
  background: linear-gradient(135deg, rgba(40, 80, 40, 0.4) 0%, rgba(20, 50, 20, 0.6) 100%);
  box-shadow: 0 0 15rpx rgba(80, 255, 80, 0.2), inset 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

/* 不同类型塔的边框颜色 */
.inventory-slot.tower-fire {
  border-color: rgba(255, 68, 0, 0.6);
  box-shadow: 0 0 15rpx rgba(255, 68, 0, 0.3);
}

.inventory-slot.tower-ice {
  border-color: rgba(0, 204, 255, 0.6);
  box-shadow: 0 0 15rpx rgba(0, 204, 255, 0.3);
}

.inventory-slot.tower-nature {
  border-color: rgba(68, 255, 68, 0.6);
  box-shadow: 0 0 15rpx rgba(68, 255, 68, 0.3);
}

.inventory-slot.tower-arcane {
  border-color: rgba(170, 68, 255, 0.6);
  box-shadow: 0 0 15rpx rgba(170, 68, 255, 0.3);
}

.inventory-slot.tower-lightning {
  border-color: rgba(255, 255, 0, 0.6);
  box-shadow: 0 0 15rpx rgba(255, 255, 0, 0.3);
}

.inventory-slot.dragging {
  opacity: 0.4;
  transform: scale(0.9);
  border-style: dashed;
}

.inventory-slot.merge-target {
  border-color: #ffd700 !important;
  box-shadow: 0 0 20px rgba(255, 215, 0, 0.8), 0 0 40px rgba(255, 215, 0, 0.4) !important;
  animation: mergeTargetPulse 0.5s ease-in-out infinite;
}

@keyframes mergeTargetPulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

.inventory-slot.empty {
  border-style: dashed;
  border-color: rgba(80, 255, 80, 0.2);
}

.slot-tower {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.tower-shape {
  width: 100%;
  height: 100%;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ===== 火焰塔 - 熔岩石塔 ===== */
.fire-shape {
  position: relative;
}
.fire-body {
  width: 24rpx;
  height: 30rpx;
  background: linear-gradient(0deg, #441100 0%, #883311 40%, #aa5533 100%);
  clip-path: polygon(10% 100%, 25% 10%, 38% 0%, 62% 0%, 75% 10%, 90% 100%);
  position: absolute;
  bottom: 0rpx;
  border-radius: 2rpx 2rpx 0 0;
}
.fire-flame {
  width: 20rpx;
  height: 24rpx;
  position: absolute;
  top: -2rpx;
  background: radial-gradient(ellipse at 50% 90%, #ffffff 0%, #ffff44 15%, #ff8800 40%, #ff4400 65%, rgba(255, 30, 0, 0) 100%);
  clip-path: polygon(50% 0%, 85% 30%, 75% 60%, 90% 75%, 50% 100%, 10% 75%, 25% 60%, 15% 30%);
  animation: flameFlicker 0.3s ease-in-out infinite alternate;
  filter: brightness(1.1);
}
@keyframes flameFlicker {
  0% { transform: scaleX(0.92) scaleY(1.06); opacity: 0.9; }
  100% { transform: scaleX(1.08) scaleY(0.94); opacity: 1; }
}

/* ===== 寒冰塔 - 冰锥尖塔 ===== */
.ice-shape {
  position: relative;
}
.ice-crystal {
  width: 12rpx;
  height: 10rpx;
  background: linear-gradient(135deg, #003344 0%, #006688 100%);
  position: absolute;
  bottom: 0rpx;
  clip-path: polygon(0% 100%, 15% 0%, 85% 0%, 100% 100%);
}
.ice-shine {
  position: absolute;
  bottom: 8rpx;
  width: 0;
  height: 0;
  border-left: 8rpx solid transparent;
  border-right: 8rpx solid transparent;
  border-bottom: 36rpx solid #33bbdd;
  filter: brightness(1.1);
}
.ice-shine::after {
  content: '';
  position: absolute;
  top: 6rpx;
  left: -4rpx;
  width: 0;
  height: 0;
  border-left: 4rpx solid transparent;
  border-right: 4rpx solid transparent;
  border-bottom: 26rpx solid rgba(200, 240, 255, 0.4);
}

/* ===== 自然塔 - 生命之树 ===== */
.nature-shape {
  position: relative;
}
.nature-trunk {
  width: 8rpx;
  height: 22rpx;
  background: linear-gradient(90deg, #2a1500 0%, #5a3000 50%, #3d2200 100%);
  position: absolute;
  bottom: 0rpx;
  border-radius: 2rpx;
}
.nature-canopy {
  width: 34rpx;
  height: 30rpx;
  position: absolute;
  top: 0rpx;
  background: radial-gradient(circle at 40% 35%, #66ee44 0%, #33aa22 50%, #116600 100%);
  border-radius: 50% 50% 45% 45%;
  box-shadow: inset -4rpx -4rpx 8rpx rgba(0, 40, 0, 0.3), inset 4rpx 4rpx 6rpx rgba(150, 255, 100, 0.15);
}
.nature-canopy::before {
  content: '';
  position: absolute;
  width: 10rpx;
  height: 8rpx;
  background: rgba(180, 255, 120, 0.4);
  border-radius: 50%;
  top: 6rpx;
  left: 8rpx;
}

/* ===== 奥术塔 - 悬浮宝石 ===== */
.arcane-shape {
  position: relative;
}
.arcane-base {
  width: 18rpx;
  height: 14rpx;
  background: linear-gradient(135deg, #555577, #333355, #222233);
  clip-path: polygon(15% 100%, 0% 0%, 100% 0%, 85% 100%);
  position: absolute;
  bottom: 0rpx;
}
.arcane-gem {
  width: 24rpx;
  height: 28rpx;
  background: linear-gradient(135deg, #ee99ff 0%, #aa44dd 40%, #6622aa 70%, #330066 100%);
  clip-path: polygon(50% 0%, 100% 40%, 50% 100%, 0% 40%);
  position: absolute;
  top: 0rpx;
  animation: gemFloat 1.5s ease-in-out infinite alternate;
}
.arcane-gem::after {
  content: '';
  position: absolute;
  width: 8rpx;
  height: 10rpx;
  background: rgba(255, 200, 255, 0.4);
  clip-path: polygon(0% 0%, 100% 50%, 30% 100%);
  top: 6rpx;
  left: 4rpx;
}
@keyframes gemFloat {
  0% { transform: translateY(1rpx); }
  100% { transform: translateY(-3rpx); }
}

/* ===== 闪电塔 - 能量方尖碑 ===== */
.lightning-shape {
  position: relative;
}
.lightning-coil {
  width: 0;
  height: 0;
  border-left: 7rpx solid transparent;
  border-right: 7rpx solid transparent;
  border-bottom: 34rpx solid #555540;
  position: absolute;
  bottom: 0rpx;
}
.lightning-coil::after {
  content: '';
  position: absolute;
  bottom: -34rpx;
  left: -10rpx;
  width: 20rpx;
  height: 10rpx;
  background: linear-gradient(135deg, #2a2a20 0%, #4a4a30 50%, #2a2a20 100%);
  clip-path: polygon(0% 100%, 10% 0%, 90% 0%, 100% 100%);
}
.lightning-orb {
  width: 14rpx;
  height: 14rpx;
  background: radial-gradient(circle at 35% 35%, #ffffff 0%, #ffff88 30%, #ddcc00 70%, rgba(180, 180, 0, 0) 100%);
  border-radius: 50%;
  position: absolute;
  top: 2rpx;
  box-shadow: 0 0 10rpx rgba(255, 255, 0, 0.9), 0 0 20rpx rgba(255, 255, 0, 0.4);
  animation: orbPulse 0.5s ease-in-out infinite alternate;
}
@keyframes orbPulse {
  0% { box-shadow: 0 0 6rpx rgba(255, 255, 0, 0.6); transform: scale(0.95); }
  100% { box-shadow: 0 0 16rpx rgba(255, 255, 0, 1); transform: scale(1.05); }
}

.tower-level-badge {
  position: absolute;
  top: 3rpx;
  right: 3rpx;
  background: linear-gradient(135deg, #ffd700 0%, #ff9500 100%);
  padding: 1rpx 8rpx;
  border-radius: 8rpx;
  box-shadow: 0 2rpx 5rpx rgba(0, 0, 0, 0.3);
}

.tower-level {
  font-size: 16rpx;
  color: #1a1a00;
  font-weight: bold;
}

.tower-name {
  margin-top: 1rpx;
}

.tower-name text {
  font-size: 16rpx;
  color: rgba(255, 255, 255, 0.7);
}

.empty-slot {
  font-size: 36rpx;
  color: rgba(80, 255, 80, 0.25);
}

/* 拖动浮层 */
.drag-floating-tower {
  position: fixed;
  width: 90rpx;
  height: 90rpx;
  margin-left: -45rpx;
  margin-top: -45rpx;
  z-index: 999;
  pointer-events: none;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 3rpx solid;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.4);
  opacity: 0.9;
}

.drag-float-body {
  width: 54rpx;
  height: 54rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.drag-float-emoji {
  font-size: 28rpx;
}

.drag-float-level {
  position: absolute;
  bottom: -4rpx;
  background: linear-gradient(135deg, #ffd700 0%, #ff9500 100%);
  padding: 0 10rpx;
  border-radius: 8rpx;
}

.drag-float-level text {
  font-size: 16rpx;
  color: #1a1a00;
  font-weight: bold;
}

/* 战前准备 */
.prep-hud {
  padding: 16rpx 18rpx 14rpx;
  background: linear-gradient(180deg, rgba(14, 34, 14, 0.96) 0%, rgba(8, 20, 8, 0.92) 100%);
  border-bottom: 2rpx solid rgba(80, 255, 80, 0.16);
  box-shadow: 0 8rpx 22rpx rgba(0, 0, 0, 0.18);
}

.prep-hud-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.prep-copy {
  flex: 1;
  min-width: 0;
}

.prep-hud-eyebrow {
  display: block;
  font-size: 18rpx;
  letter-spacing: 3rpx;
  color: rgba(168, 255, 168, 0.54);
}

.prep-hud-title {
  display: block;
  margin-top: 6rpx;
  font-size: 28rpx;
  font-weight: 800;
  color: #8bff7b;
  line-height: 1.35;
  text-shadow: 0 0 14rpx rgba(120, 255, 120, 0.22);
}

.prep-progress {
  flex-shrink: 0;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.08);
  background: rgba(255, 255, 255, 0.04);
}

.prep-progress.ready {
  border-color: rgba(139, 255, 123, 0.42);
  box-shadow: 0 0 18rpx rgba(120, 255, 120, 0.18);
}

.prep-progress text {
  font-size: 20rpx;
  color: rgba(245, 252, 240, 0.84);
  font-weight: 700;
}

.prep-step-line {
  display: flex;
  gap: 10rpx;
  margin-top: 14rpx;
}

.prep-step {
  flex: 1;
  min-width: 0;
  text-align: center;
  padding: 8rpx 0;
  border-radius: 999rpx;
  font-size: 18rpx;
  color: rgba(220, 255, 220, 0.56);
  background: rgba(255, 255, 255, 0.04);
  border: 2rpx solid rgba(255, 255, 255, 0.05);
}

.prep-step.active {
  color: #fff4cf;
  border-color: rgba(255, 215, 120, 0.45);
  background: rgba(255, 215, 120, 0.1);
}

.prep-step.done,
.prep-step.ready {
  color: #9bff86;
  border-color: rgba(139, 255, 123, 0.35);
  background: rgba(139, 255, 123, 0.08);
}

.blessing-quick-list {
  display: flex;
  gap: 10rpx;
  margin-top: 14rpx;
}

.blessing-quick-card {
  flex: 1;
  min-width: 0;
  padding: 14rpx 14rpx;
  border-radius: 18rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.08);
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.05) 0%, rgba(255, 255, 255, 0.02) 100%);
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.blessing-quick-list.compact .blessing-quick-card {
  align-items: center;
  justify-content: center;
  padding: 12rpx 10rpx;
}

.blessing-quick-card.selected {
  border-color: rgba(255, 215, 120, 0.75);
  box-shadow: 0 0 20rpx rgba(255, 215, 120, 0.16);
  background: linear-gradient(135deg, rgba(255, 214, 94, 0.15) 0%, rgba(255, 168, 42, 0.05) 100%);
}

.blessing-quick-icon {
  font-size: 28rpx;
}

.blessing-quick-name {
  display: block;
  font-size: 22rpx;
  font-weight: 700;
  color: #ffffff;
}

.blessing-quick-list.compact .blessing-quick-name {
  font-size: 20rpx;
  text-align: center;
}

.blessing-quick-subtitle {
  display: block;
  font-size: 17rpx;
  line-height: 1.4;
  color: rgba(255, 240, 200, 0.72);
}

.prep-footer {
  margin-top: 14rpx;
}

.prep-footer.compact {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.prep-footnote {
  display: block;
  margin-bottom: 14rpx;
  text-align: center;
  color: rgba(255, 255, 255, 0.68);
  font-size: 20rpx;
}

.prep-footer.compact .prep-footnote {
  flex: 1;
  margin-bottom: 0;
  text-align: left;
  line-height: 1.5;
}

.prep-footnote.ready {
  color: #9bff86;
}

.prep-start-btn {
  width: 210rpx;
  flex-shrink: 0;
  height: 74rpx;
  margin-bottom: 0;
  font-size: 26rpx;
}

/* 遮罩和面板 */
.overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(5, 15, 5, 0.95);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.panel {
  width: 85%;
  max-width: 580rpx;
  padding: 55rpx 45rpx;
  background: linear-gradient(135deg, rgba(40, 80, 40, 0.3) 0%, rgba(20, 50, 20, 0.4) 100%);
  border: 3rpx solid rgba(80, 255, 80, 0.5);
  border-radius: 35rpx;
  box-shadow: 0 0 50rpx rgba(80, 255, 80, 0.2), inset 0 2rpx 15rpx rgba(255, 255, 255, 0.05);
}

.supply-panel {
  width: 88%;
  max-width: 620rpx;
  padding: 48rpx 34rpx 34rpx;
}

.supply-subtitle {
  display: block;
  margin-top: -18rpx;
  margin-bottom: 26rpx;
  text-align: center;
  font-size: 24rpx;
  color: rgba(220, 255, 220, 0.72);
}

.supply-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.supply-card {
  padding: 24rpx 22rpx;
  border-radius: 24rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.08);
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.06) 0%, rgba(255, 255, 255, 0.02) 100%);
}

.supply-card:active {
  transform: scale(0.98);
  border-color: rgba(255, 215, 120, 0.55);
}

.supply-icon {
  display: block;
  font-size: 42rpx;
}

.supply-name {
  display: block;
  margin-top: 10rpx;
  font-size: 30rpx;
  font-weight: 800;
  color: #fff5c8;
}

.supply-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: rgba(230, 255, 230, 0.72);
}

.panel-title {
  display: block;
  text-align: center;
  font-size: 52rpx;
  font-weight: bold;
  color: #50ff50;
  margin-bottom: 40rpx;
  text-shadow: 0 0 25rpx rgba(80, 255, 80, 0.8), 0 3rpx 6rpx rgba(0, 0, 0, 0.5);
}

.panel-title.gameover {
  color: #ff6666;
  text-shadow: 0 0 25rpx rgba(255, 102, 102, 0.8), 0 3rpx 6rpx rgba(0, 0, 0, 0.5);
}

.panel-stats {
  margin-bottom: 40rpx;
}

.panel-stat {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 25rpx;
  background: linear-gradient(135deg, rgba(0, 0, 0, 0.4) 0%, rgba(0, 0, 0, 0.2) 100%);
  border-radius: 15rpx;
  margin-bottom: 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.panel-stat-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
}

.panel-stat-value {
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.5);
}

.panel-stat-value.big {
  font-size: 46rpx;
  color: #ffd700;
  text-shadow: 0 0 15rpx rgba(255, 215, 0, 0.5);
}

.panel-stat-value.gold-text {
  color: #ffd700;
  text-shadow: 0 0 15rpx rgba(255, 215, 0, 0.5);
}

.record {
  text-align: center;
  padding: 22rpx;
  background: linear-gradient(135deg, rgba(255, 170, 0, 0.2) 0%, rgba(255, 200, 0, 0.15) 100%);
  border-radius: 15rpx;
  margin-top: 12rpx;
  border: 2rpx solid rgba(255, 170, 0, 0.4);
}

.record text {
  font-size: 40rpx;
  color: #ffaa00;
  animation: recordPulse 1s ease-in-out infinite;
  text-shadow: 0 0 15rpx rgba(255, 170, 0, 0.6);
}

@keyframes recordPulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

.btn {
  width: 100%;
  height: 95rpx;
  border-radius: 20rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn.primary {
  background: linear-gradient(135deg, #50ff50 0%, #20aa20 100%);
  color: #0d1f0d;
  box-shadow: 0 0 25rpx rgba(80, 255, 80, 0.5), inset 0 2rpx 8rpx rgba(255, 255, 255, 0.2);
}

.btn.primary.disabled,
.btn.primary[disabled] {
  background: linear-gradient(135deg, rgba(97, 116, 97, 0.9) 0%, rgba(66, 80, 66, 0.92) 100%);
  color: rgba(226, 236, 226, 0.62);
  box-shadow: none;
}

.btn.primary:active {
  background: linear-gradient(135deg, #40dd40 0%, #188818 100%);
  box-shadow: 0 0 35rpx rgba(80, 255, 80, 0.7);
}

.btn.secondary {
  background: linear-gradient(135deg, rgba(80, 80, 80, 0.4) 0%, rgba(50, 50, 50, 0.5) 100%);
  border: 2rpx solid rgba(255, 255, 255, 0.25);
  color: rgba(255, 255, 255, 0.85);
}

.btn.secondary:active {
  background: rgba(100, 100, 100, 0.5);
}
