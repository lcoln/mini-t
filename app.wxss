/**app.wxss**/
page {
  background: #1a2a1a;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  -webkit-font-smoothing: antialiased;
}

button {
  margin: 0;
  padding: 0;
  background: transparent;
  border: none;
  outline: none;
}

button::after {
  border: none;
}

view, text {
  box-sizing: border-box;
}
